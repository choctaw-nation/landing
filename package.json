{
  "name": "choctaw-landing",
  "version": "3.4.0",
  "description": "A custom wp theme for choctaw-landing",
  "prettier": "@wordpress/prettier-config",
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "scripts": {
    "build": "wp-scripts build",
    "lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix",
    "lint:js": "npx eslint --fix",
    "check-engines": "wp-scripts check-engines",
    "packages-update": "wp-scripts packages-update",
    "start": "wp-scripts start",
    "test:local": "wp-scripts test-playwright --timeout=15000",
    "test:dev": "BASE_URL=https://choctawlandev.wpenginepowered.com/ wp-scripts test-playwright --timeout=15000",
    "test:stg": "BASE_URL=https://choctawlandstg.wpenginepowered.com/ wp-scripts test-playwright --timeout=15000"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choctaw-nation/landing.git"
  },
  "author": "Choctaw Nation of Oklahoma",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/choctaw-nation/landing/issues"
  },
  "homepage": "https://github.com/choctaw-nation/landing#readme",
  "dependencies": {
    "@choctawnationofoklahoma/wp-flex-reverse-toggle": "^1.1.2",
    "bootstrap": "^5.3.8",
    "daterangepicker": "^3.1.0",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.37",
    "@wordpress/e2e-test-utils-playwright": "^1.41.0",
    "@wordpress/eslint-plugin": "^24.3.0",
    "@wordpress/scripts": "^31.6.0",
    "bootstrap-icons": "^1.13.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "webpack-remove-empty-scripts": "^1.1.1"
  }
}
